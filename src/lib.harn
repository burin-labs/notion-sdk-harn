/** Exchange an authorization code for an access and refresh token */
pub fn create_a_token(client: dict, body) -> CreateATokenResponse {
  let path_bindings = {}
  let path = _interpolate("/v1/oauth/token", path_bindings)
  let url = client.base_url + path
  let body_variant = if type_of(body) == "dict" {
    body.get("_variant")
  } else {
    nil
  }
  if body_variant == nil {
    throw "create_a_token: polymorphic request body must be built with one of: create_a_token_variant1, create_a_token_variant2"
  }
  if !["Variant1", "Variant2"].contains(body_variant) {
    throw "create_a_token: unknown request body variant " + to_string(body_variant)
  }
  let body_str = json_stringify(_strip_codegen_variant(body))
  let resp = http_post(url, body_str, {headers: _headers_basicauth(client)})
  if resp.status >= 400 {
    throw "create_a_token: HTTP " + to_string(resp.status) + " " + resp.body
  }
  let raw = json_parse(resp.body)
  if type_of(raw) != "dict" {
    throw "create_a_token: expected dict response, got " + type_of(raw)
  }
  return raw
}

pub fn create_a_token_variant1(code: string, external_account = nil, redirect_uri = nil) -> dict {
  var body = {code: code, grant_type: "authorization_code", _variant: "Variant1"}
  if external_account != nil {
    body = {...body, external_account: external_account}
  }
  if redirect_uri != nil {
    body = {...body, redirect_uri: redirect_uri}
  }
  return body
}

pub fn create_a_token_variant2(refresh_token: string) -> dict {
  var body = {grant_type: "refresh_token", refresh_token: refresh_token, _variant: "Variant2"}
  return body
}

