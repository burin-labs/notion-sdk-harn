  let path = _interpolate("/v1/file_uploads/{file_upload_id}/send", path_bindings)
  let url = client.base_url + path
  let body_str = json_stringify(body)
  let resp = http_post(url, body_str, {headers: _headers_bearerauth(client)})
  if resp.status >= 400 {
    throw "upload_file: HTTP " + to_string(resp.status) + " " + resp.body
  }
  let raw = json_parse(resp.body)
  if type_of(raw) != "dict" {
    throw "upload_file: expected dict response, got " + type_of(raw)
  }
  return raw
}

