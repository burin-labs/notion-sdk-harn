/** Update a page's content as markdown */
pub fn update_page_markdown(client: dict, page_id, body) -> PageMarkdownResponse {
  let path_bindings = {page_id: page_id}
  let path = _interpolate("/v1/pages/{page_id}/markdown", path_bindings)
  let url = client.base_url + path
  let body_variant = if type_of(body) == "dict" {
    body.get("_variant")
  } else {
    nil
  }
  if body_variant == nil {
    throw "update_page_markdown: polymorphic request body must be built with one of: update_page_markdown_insert_content, update_page_markdown_replace_content_range, update_page_markdown_update_content, update_page_markdown_replace_content"
  }
  if !["InsertContent", "ReplaceContentRange", "UpdateContent", "ReplaceContent"].contains(body_variant) {
    throw "update_page_markdown: unknown request body variant " + to_string(body_variant)
  }
  let body_str = json_stringify(_strip_codegen_variant(body))
  let resp = http_patch(url, body_str, {headers: _headers_bearerauth(client)})
  if resp.status >= 400 {
    throw "update_page_markdown: HTTP " + to_string(resp.status) + " " + resp.body
  }
  let raw = json_parse(resp.body)
  if type_of(raw) != "dict" {
    throw "update_page_markdown: expected dict response, got " + type_of(raw)
  }
  return raw
}

pub fn update_page_markdown_insert_content(insert_content: dict) -> dict {
  var body = {insert_content: insert_content, type: "insert_content", _variant: "InsertContent"}
  return body
}

pub fn update_page_markdown_replace_content_range(replace_content_range: dict) -> dict {
  var body = {
    replace_content_range: replace_content_range,
    type: "replace_content_range",
    _variant: "ReplaceContentRange",
  }
  return body
}

pub fn update_page_markdown_update_content(update_content: dict) -> dict {
  var body = {type: "update_content", update_content: update_content, _variant: "UpdateContent"}
  return body
}

pub fn update_page_markdown_replace_content(replace_content: dict) -> dict {
  var body = {replace_content: replace_content, type: "replace_content", _variant: "ReplaceContent"}
  return body
}

